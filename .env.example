APP_NAME=ReelEmpire-CoD-Pro
ENVIRONMENT=development
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg2://reel_empire:reel_empire@postgres:5432/reel_empire
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//
REDIS_URL=redis://redis:6379/0

AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=us-east-1
S3_BUCKET_RAW_COD=your-raw-cod-bucket
S3_BUCKET_OUTPUT=your-output-videos-bucket

ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
GROK_API_KEY=YOUR_GROK_API_KEY
GROK_BASE_URL=https://api.x.ai/v1
OLLAMA_BASE_URL=http://host.docker.internal:11434
SCRIPT_MODEL_PRIMARY=claude-sonnet-4-20250514
SCRIPT_MODEL_FALLBACK=grok-2-latest
SCRIPT_MODEL_LOCAL=llama3.1:405b

ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY
ELEVENLABS_VOICE_FINANCE=VOICE_ID_FINANCE
ELEVENLABS_VOICE_RELATIONSHIPS=VOICE_ID_RELATIONSHIPS
ELEVENLABS_VOICE_HEALTH=VOICE_ID_HEALTH
ELEVENLABS_VOICE_CULTURE=VOICE_ID_CULTURE

META_GRAPH_ACCESS_TOKEN=YOUR_META_TOKEN
META_INSTAGRAM_BUSINESS_ID=YOUR_IG_BUSINESS_ID
TIKTOK_ACCESS_TOKEN=YOUR_TIKTOK_TOKEN
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY
YOUTUBE_CHANNEL_ID=YOUR_YOUTUBE_CHANNEL_ID

LOCAL_CLIPS_DIR=/data/clips
LOCAL_MUSIC_DIR=/data/music
LOCAL_OUTPUT_DIR=/data/output
DEFAULT_BATCH_SIZE=50
MAX_BATCH_SIZE=2000
COD_USAGE_TARGET_RATIO=0.8
PEXELS_API_KEY=

ENABLE_SCHEDULER=true
SCHEDULE_CRON=0 */2 * * *
REVIEW_REQUIRED=true

ACCOUNT_ROTATION_ENABLED=true
POSTING_MIN_GAP_SECONDS=1200
DAILY_POST_LIMIT_PER_ACCOUNT=20
PLATFORM_PROXY_URL=
